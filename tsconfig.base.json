{
  "compilerOptions": {
    "target": "ES2019"
  , "module": "NodeNext"
  , "moduleResolution": "NodeNext"
  , "esModuleInterop": true
  , "strict": true
  , "noUnusedLocals": true
  , "noUnusedParameters": false
  , "rootDir": "src"
  , "types": ["*"]
  , "paths": {
      "@src/*": ["./src/*"]
    , "@utils/*": ["./src/utils/*"]
    , "@test/*": ["./__tests__/*"]
    }
  , "plugins": [
      { "transform": "typescript-transform-paths" }
    , { "transform": "typescript-transform-paths", "afterDeclarations": true }
    ]
  }
}
